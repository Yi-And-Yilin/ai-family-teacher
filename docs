### 2.3 行前缀协议

AI输出使用 `W>` 前缀标识做题册内容：

```
W> 【题目】
W> 水果店里，苹果每个5元，小明买了3个苹果...
W> 请问小明一共花了多少钱？
W> A. 15元
W> B. 21元
W> C. 24元
W> D. 27元
```

### 2.4 核心代码

#### WorkbookWidget (`workbook.dart`)

```dart
class WorkbookWidget extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    final appProvider = Provider.of<AppProvider>(context);
    final workbookContent = appProvider.streamingWorkbookContent;
    final hasContent = workbookContent.isNotEmpty;
    
    return Container(
      // 桌面背景
      color: const Color(0xFFE0E0E0),
      child: Container(
        // 护眼米黄纸张
        decoration: BoxDecoration(
          color: const Color(0xFFFFFDE7),
          borderRadius: BorderRadius.circular(4),
        ),
        child: Stack(
          children: [
            // 横线和红色边线
            Positioned.fill(child: CustomPaint(
              painter: _WorkbookPaperPainter()
            )),
            
            // AI批改痕迹
            Positioned.fill(child: CustomPaint(
              painter: _WorkbookMarkPainter(appProvider.workbookMarks)
            )),
            
            // 题目内容
            if (hasContent)
              Text(workbookContent, ...),
          ],
        ),
      ),
    );
  }
}
```

#### 批改痕迹绘制

```dart
class _WorkbookMarkPainter extends CustomPainter {
  final List<Map<String, dynamic>> marks;
  
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = Colors.red.withOpacity(0.8)
      ..strokeWidth = 2.0;
    
    for (final mark in marks) {
      final type = mark['type'];
      final dx = mark['position']['x'];
      final dy = mark['position']['y'];
      
      if (type == 'tick') {
        // 画对勾 ✓
        final path = Path()
          ..moveTo(dx - 10, dy)
          ..lineTo(dx - 2, dy + 10)
          ..lineTo(dx + 15, dy - 15);
        canvas.drawPath(path, paint);
      } else if (type == 'cross') {
        // 画叉 ✗
        canvas.drawLine(Offset(dx - 10, dy - 10), Offset(dx + 10, dy + 10), paint);
        canvas.drawLine(Offset(dx + 10, dy - 10), Offset(dx - 10, dy + 10), paint);
      } else if (type == 'circle') {
        // 画圈 ○
        canvas.drawCircle(Offset(dx, dy), 30, paint);
      }
    }
  }
}
```

